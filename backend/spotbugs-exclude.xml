<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                            https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2
        ================================
        SpotBugs flags every Lombok @Data / @Builder / @RequiredArgsConstructor
        getter, setter, and constructor that touches a mutable type (User, List,
        Map, ObjectMapper, …) as potentially exposing internal representation.

DTOs are short-lived serialization objects and are not intended to provide
defensive-copy semantics. SpotBugs reports on these classes create noise
without identifying meaningful defects.
        These are false positives for this project because:
          - JPA entities require mutable references (Hibernate proxies, lazy loading).
          - Spring @Component / @Service / @RestController beans are singletons
            managed by the IoC container; defensive copies would break injection.
          - DTOs transferred over the wire do not need immutability guarantees.

        Suppressing these two patterns project-wide keeps the report focused on
        genuinely actionable findings.
    -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

</FindBugsFilter>
