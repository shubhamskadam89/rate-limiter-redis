    {
      "name": "Sale Events (Admin)",
      "item": [
        {
          "name": "10 - Create Sale Event",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var now = new Date();",
                  "var start = new Date(now.getTime() + 2 * 60 * 1000);",
                  "var end   = new Date(now.getTime() + 62 * 60 * 1000);",
                  "function fmt(d) {",
                  "    var p = n => String(n).padStart(2,'0');",
                  "    return d.getFullYear()+'-'+p(d.getMonth()+1)+'-'+p(d.getDate())+'T'+p(d.getHours())+':'+p(d.getMinutes())+':'+p(d.getSeconds());",
                  "}",
                  "pm.collectionVariables.set('saleStartTime', fmt(start));",
                  "pm.collectionVariables.set('saleEndTime', fmt(end));",
                  "console.log('Sale window:', fmt(start), '->', fmt(end));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Sale event created and UUID captured', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var j = pm.response.json();",
                  "    pm.expect(j).to.have.property('saleUuid');",
                  "    pm.collectionVariables.set('saleUuid', j.saleUuid);",
                  "    console.log('Sale UUID:', j.saleUuid);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Flash Sale\",\n  \"startTime\": \"{{saleStartTime}}\",\n  \"endTime\": \"{{saleEndTime}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/sales",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "sales"]
            }
          },
          "response": []
        },
